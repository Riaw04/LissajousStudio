<Window x:Class="LissajousStudio.App.Views.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:rendering="clr-namespace:LissajousStudio.Rendering.Controls;assembly=LissajousStudio.Rendering" Title="LissajousStudio" Width="1440" Height="900" Background="{StaticResource AppBackground}" WindowStartupLocation="CenterScreen">
  <Grid Margin="18">
    <Grid.RowDefinitions><RowDefinition Height="64"/><RowDefinition Height="*"/><RowDefinition Height="190"/><RowDefinition Height="28"/></Grid.RowDefinitions>
    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="300"/></Grid.ColumnDefinitions>
    <Border Grid.ColumnSpan="2" Style="{StaticResource Panel}"><DockPanel><TextBlock Text="LissajousStudio" FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"/><StackPanel Orientation="Horizontal" DockPanel.Dock="Right"><Button Content="Start" Command="{Binding StartCommand}"/><Button Content="Stop" Command="{Binding StopCommand}" Margin="10,0,0,0"/></StackPanel></DockPanel></Border>
    <Border Grid.Row="1" Margin="0,14,14,14" Style="{StaticResource Panel}"><rendering:OscilloscopeControl SampleBuffer="{Binding Buffer}"/></Border>
    <Border Grid.Row="1" Grid.Column="1" Margin="0,14,0,14" Style="{StaticResource Panel}"><StackPanel><TextBlock Text="Measurements" Style="{StaticResource SectionTitle}"/><TextBlock Text="Circle lock: 90°" Foreground="{StaticResource MeasurementBrush}"/><TextBlock Text="Sample Rate" Margin="0,20,0,4"/><TextBlock Text="{Binding SampleRate, StringFormat={}{0} Hz}" Foreground="{StaticResource MeasurementBrush}"/><TextBlock Text="FPS" Margin="0,20,0,4"/><TextBlock Text="{Binding FramesPerSecond, StringFormat={}{0:F1}}" Foreground="{StaticResource MeasurementBrush}"/></StackPanel></Border>
    <Border Grid.Row="2" Grid.ColumnSpan="2" Style="{StaticResource Panel}"><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Frequency" Style="{StaticResource SectionTitle}"/><Slider Minimum="20" Maximum="2000" Value="{Binding FrequencyHz}"/><TextBlock Text="{Binding FrequencyHz, StringFormat={}{0:F1} Hz}"/></StackPanel><StackPanel Grid.Column="1" Margin="20,0"><TextBlock Text="Amplitude" Style="{StaticResource SectionTitle}"/><Slider Minimum="0" Maximum="1" Value="{Binding Amplitude}"/><TextBlock Text="{Binding Amplitude, StringFormat={}{0:P0}}"/></StackPanel><StackPanel Grid.Column="2"><TextBlock Text="Phase" Style="{StaticResource SectionTitle}"/><Slider Minimum="0" Maximum="360" Value="{Binding PhaseDegrees}"/><TextBlock Text="{Binding PhaseDegrees, StringFormat={}{0:F0}°}"/></StackPanel></Grid></Border>
    <TextBlock Grid.Row="3" Grid.ColumnSpan="2" Text="Ready • Stereo buffer is the single source of truth • Left=X Right=Y" Foreground="#8899A6" VerticalAlignment="Center"/>
  </Grid>
</Window>
