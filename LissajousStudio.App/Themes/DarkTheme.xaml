<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Color x:Key="BackgroundColor">#090D12</Color><SolidColorBrush x:Key="AppBackground" Color="{StaticResource BackgroundColor}"/><SolidColorBrush x:Key="AccentBrush" Color="#00D9FF"/><SolidColorBrush x:Key="MeasurementBrush" Color="#50FA7B"/><SolidColorBrush x:Key="PanelBrush" Color="#141B24"/><SolidColorBrush x:Key="TextBrush" Color="#E6EDF3"/>
  <Style TargetType="TextBlock"><Setter Property="Foreground" Value="{StaticResource TextBrush}"/><Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI"/></Style>
  <Style x:Key="SectionTitle" TargetType="TextBlock"><Setter Property="FontSize" Value="16"/><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Margin" Value="0,0,0,12"/></Style>
  <Style x:Key="Panel" TargetType="Border"><Setter Property="Background" Value="{StaticResource PanelBrush}"/><Setter Property="CornerRadius" Value="18"/><Setter Property="Padding" Value="18"/></Style>
  <Style TargetType="Button"><Setter Property="Foreground" Value="#061014"/><Setter Property="Background" Value="{StaticResource AccentBrush}"/><Setter Property="Padding" Value="18,9"/><Setter Property="BorderThickness" Value="0"/><Setter Property="FontWeight" Value="SemiBold"/></Style>
  <Style TargetType="TextBox"><Setter Property="Foreground" Value="{StaticResource TextBrush}"/><Setter Property="Background" Value="#0D131A"/><Setter Property="BorderBrush" Value="#263646"/><Setter Property="CaretBrush" Value="{StaticResource AccentBrush}"/><Setter Property="Padding" Value="8"/></Style>
</ResourceDictionary>
